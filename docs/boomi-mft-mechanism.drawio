<mxfile host="app.diagrams.net" modified="2026-07-07T10:00:00.000Z" agent="Intelligrator" version="24.0.0">
  <diagram id="boomi-mft-mechanism" name="How Boomi Achieves MFT">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1250" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="How Boomi Achieves Managed File Transfer — mechanism &amp; error notification" style="text;html=1;fontSize=17;fontStyle=1;fontColor=#1F4E79;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="15" width="1000" height="30" as="geometry" />
        </mxCell>

        <mxCell id="trigger" value="Schedule&#10;(Start shape, cron)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F6674;strokeColor=#0A4A54;fontColor=#FFFFFF;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="30" y="120" width="120" height="60" as="geometry" />
        </mxCell>

        <mxCell id="atom" value="Boomi Atom — Deployed Process (Option A)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F9FF;strokeColor=#1F4E79;verticalAlign=top;fontStyle=1;fontColor=#1F4E79" vertex="1" parent="1">
          <mxGeometry x="190" y="90" width="560" height="300" as="geometry" />
        </mxCell>
        <mxCell id="tryBox" value="Try / Catch (retry count 0–5)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#B26A00;dashed=1;verticalAlign=top;fontColor=#B26A00;fontStyle=1;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="210" y="125" width="330" height="150" as="geometry" />
        </mxCell>
        <mxCell id="src" value="Source Connector&#10;Disk/SFTP/FTPS/AS2 — Get" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE6F1;strokeColor=#1F4E79" vertex="1" parent="1">
          <mxGeometry x="225" y="155" width="140" height="55" as="geometry" />
        </mxCell>
        <mxCell id="xform" value="Validate / Transform&#10;profile, checksum (optional)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE6F1;strokeColor=#1F4E79" vertex="1" parent="1">
          <mxGeometry x="385" y="155" width="140" height="55" as="geometry" />
        </mxCell>
        <mxCell id="dst" value="Destination Connector&#10;Disk/SFTP/FTPS — Send" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE6F1;strokeColor=#1F4E79" vertex="1" parent="1">
          <mxGeometry x="225" y="222" width="140" height="45" as="geometry" />
        </mxCell>
        <mxCell id="post" value="Post-action&#10;archive / delete / rename" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE6F1;strokeColor=#1F4E79" vertex="1" parent="1">
          <mxGeometry x="385" y="222" width="140" height="45" as="geometry" />
        </mxCell>

        <mxCell id="catchBox" value="Catch path — on exception" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEC;strokeColor=#C62828;verticalAlign=top;fontColor=#8E1B1B;fontStyle=1;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="210" y="295" width="510" height="80" as="geometry" />
        </mxCell>
        <mxCell id="notify" value="Message / Notify&#10;error + execution ID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C62828;fontColor=#8E1B1B" vertex="1" parent="1">
          <mxGeometry x="225" y="322" width="130" height="45" as="geometry" />
        </mxCell>
        <mxCell id="mail" value="Mail Connector&#10;sends alert email" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C62828;fontColor=#8E1B1B" vertex="1" parent="1">
          <mxGeometry x="370" y="322" width="130" height="45" as="geometry" />
        </mxCell>
