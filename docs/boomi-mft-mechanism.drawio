          <mxGeometry x="515" y="322" width="190" height="45" as="geometry" />
        </mxCell>

        <mxCell id="runs" value="Process Reporting /&#10;Run Records&#10;(success + failure, exec ID)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#C62828;strokeColor=#8E1B1B;fontColor=#FFFFFF;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="785" y="140" width="150" height="90" as="geometry" />
        </mxCell>
        <mxCell id="dash" value="Run Dashboard&#10;files transferred + status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE6F1;strokeColor=#1F4E79" vertex="1" parent="1">
          <mxGeometry x="800" y="250" width="120" height="55" as="geometry" />
        </mxCell>
        <mxCell id="plat" value="Platform-level alerting&#10;• PROCESS.EXECUTION alerts (Log Level = ERROR)&#10;• USER.NOTIFICATION alerts for non-terminating warnings&#10;• Alert email links to the execution ID for fast triage&#10;• Fires only if the interface opted in" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#B26A00;fontColor=#7A4A00;align=left;spacingLeft=8;verticalAlign=top;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="960" y="115" width="250" height="150" as="geometry" />
        </mxCell>

        <mxCell id="optB" value="Option B (alternate) — Boomi native Managed File Transfer, powered by Thru" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0AAB52;strokeColor=none;fontColor=#FFFFFF;fontStyle=1;fontSize=13;arcSize=6;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="190" y="420" width="1020" height="34" as="geometry" />
        </mxCell>
        <mxCell id="optBBody" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F2FBF6;strokeColor=#0AAB52" vertex="1" parent="1">
          <mxGeometry x="190" y="454" width="1020" height="180" as="geometry" />
        </mxCell>
        <mxCell id="mgmt" value="Management Channel&#10;• Flow definitions&#10;• Partner/endpoint credentials&#10;• Tracking, audit, proof of delivery&#10;• Native alerts on failed transfers&#10;• Partner self-service portal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0AAB52;fontColor=#0A6B36;align=left;spacingLeft=8;verticalAlign=top;fontSize=10.5" vertex="1" parent="1">
          <mxGeometry x="215" y="475" width="260" height="140" as="geometry" />
        </mxCell>
        <mxCell id="dataChan" value="Data Channel&#10;• Actual file payload transfer&#10;• Persistent storage until delivered&#10;• Auto-resume, guaranteed delivery&#10;• Encrypted at rest, in transit,&#10;  and at the file level" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0AAB52;fontColor=#0A6B36;align=left;spacingLeft=8;verticalAlign=top;fontSize=10.5" vertex="1" parent="1">
          <mxGeometry x="495" y="475" width="260" height="140" as="geometry" />
        </mxCell>
        <mxCell id="mftConn" value="Boomi ↔ MFT Connector&#10;Get — pickup a file from a Flow&#10;Create — drop off a file to a Flow&#10;Create (type=Exception) — push&#10;error/exception info back into&#10;MFT's own tracking &amp; audit trail" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0AAB52;fontColor=#0A6B36;align=left;spacingLeft=8;verticalAlign=top;fontSize=10.5" vertex="1" parent="1">
          <mxGeometry x="775" y="475" width="260" height="140" as="geometry" />
        </mxCell>

        <mxCell id="footnote" value="This catalogue's P-116 pattern and the Intelligrator Generic MFT Engine use Option A. Option B is a separate licensed product, evaluated where partners need self-service endpoint management." style="text;html=1;fontSize=10;fontColor=#8a94a0;align=center;" vertex="1" parent="1">
          <mxGeometry x="190" y="650" width="1020" height="30" as="geometry" />
        </mxCell>

