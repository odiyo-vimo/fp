        <mxCell id="e10" value="failure also logged" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#C62828;dashed=1;fontSize=9" edge="1" parent="1" source="mail" target="runs"><mxGeometry relative="1" as="geometry" /></mxCell>
