        <mxCell id="n119" value="&lt;b&gt;M5 &amp;#183; W24&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;color:#5A6472&quot;&gt;Event-driven onboarding&lt;br/&gt;25 Dec&lt;/font&gt;" style="rounded=1;arcSize=18;html=1;fillColor=#FFFFFF;strokeColor=#DFE4EA;fontSize=10;fontColor=#0F1723;align=center;verticalAlign=middle;whiteSpace=wrap;spacing=3;" vertex="1" parent="1"><mxGeometry x="1272" y="726" width="168" height="48" as="geometry"/></mxCell>
