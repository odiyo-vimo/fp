<mxfile host="app.diagrams.net" modified="2026-07-14T09:00:00.000Z" agent="Integration Catalogue Bot" version="24.7.17" type="device">
  <diagram id="intelligrator-lifecycle" name="Intelligrator Request Lifecycle">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Intelligrator — Request Lifecycle (MFT and API)" style="text;html=1;fontSize=24;fontStyle=1;fontColor=#0F1723;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="700" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="One state machine serves both request types. Decision actions (Approve / Reject / Request info) require step-up authentication and are never available to the requester on their own request." style="text;html=1;fontSize=13;fontColor=#5A6472;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="54" width="1080" height="22" as="geometry"/>
        </mxCell>

        <!-- SWIM BANDS -->
        <mxCell id="band1" value="REQUESTER HOLDS" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F7FC;strokeColor=none;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontSize=11;fontStyle=1;fontColor=#8B94A1;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="1620" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="band2" value="APPROVER HOLDS" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8EC;strokeColor=none;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontSize=11;fontStyle=1;fontColor=#8B94A1;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="1620" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="band3" value="PLATFORM / TERMINAL" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F2F7F2;strokeColor=none;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontSize=11;fontStyle=1;fontColor=#8B94A1;" vertex="1" parent="1">
          <mxGeometry x="40" y="480" width="1620" height="180" as="geometry"/>
        </mxCell>

        <!-- NODES -->
        <mxCell id="start" value="" style="ellipse;html=1;fillColor=#0F1723;strokeColor=#0F1723;" vertex="1" parent="1">
          <mxGeometry x="70" y="290" width="40" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="draft" value="&lt;b&gt;Draft&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Requester · auto-saved&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#EEF2F7;strokeColor=#B9C4D0;fontColor=#12161C;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="150" y="280" width="170" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="awaiting" value="&lt;b&gt;Awaiting Information&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Editable · approver SLA paused&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#FFF1CF;strokeColor=#D8A72B;fontColor=#12161C;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="420" y="135" width="190" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="submitted" value="&lt;b&gt;Submitted&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;In approval queue · SLA running&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#DCE9FF;strokeColor=#0B5FFF;fontColor=#12161C;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="420" y="280" width="190" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="precheck" value="&lt;b&gt;Automated pre-checks&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;naming · duplicates · credentials&lt;br/&gt;contract lint · classification · capacity&lt;/font&gt;" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0B5FFF;dashed=1;fontColor=#003D9E;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="405" y="365" width="220" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="approved" value="&lt;b&gt;Approved&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Immutable · rationale recorded&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#DCF0E0;strokeColor=#3A6B35;fontColor=#12161C;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="710" y="255" width="180" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="approvedc" value="&lt;b&gt;Approved (Conditional)&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Conditions tracked to due date&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#DCF0E0;strokeColor=#3A6B35;dashed=1;fontColor=#12161C;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="710" y="330" width="180" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="rejected" value="&lt;b&gt;Rejected&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Reason code + detail · terminal&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#FBDDDB;strokeColor=#B3261E;fontColor=#12161C;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="420" y="520" width="190" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="withdrawn" value="&lt;b&gt;Withdrawn&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Terminal&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#EEF2F7;strokeColor=#8B94A1;fontColor=#12161C;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="150" y="520" width="170" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="prov" value="&lt;b&gt;Provisioning&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Writes ONE config row&lt;br/&gt;No new Boomi component&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#0F1723;strokeColor=#0F1723;fontColor=#FFFFFF;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="980" y="285" width="190" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="provfail" value="&lt;b&gt;Provisioning Failed&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Partial config rolled back&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#FBDDDB;strokeColor=#B3261E;fontColor=#12161C;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="980" y="520" width="190" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="live" value="&lt;b&gt;Live&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Smoke test passed&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#3A6B35;strokeColor=#2C5228;fontColor=#FFFFFF;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1250" y="255" width="180" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="liveu" value="&lt;b&gt;Live (Unverified)&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Smoke test failed · flagged&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#FFF1CF;strokeColor=#D8A72B;fontColor=#12161C;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1250" y="330" width="180" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="decom" value="&lt;b&gt;Decommissioned&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Config row disabled, not deleted&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#EEF2F7;strokeColor=#8B94A1;fontColor=#12161C;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1480" y="520" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- EDGES -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6472;strokeWidth=1.5;endArrow=block;endFill=1;" edge="1" parent="1" source="start" target="draft">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="Submit  (MFT-10 / API-07)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0B5FFF;strokeWidth=2;endArrow=block;endFill=1;fontSize=10;fontColor=#003D9E;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="draft" target="submitted">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="Withdraw (TRK-05)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8B94A1;strokeWidth=1.5;endArrow=block;endFill=1;fontSize=10;fontColor=#5A6472;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="draft" target="withdrawn">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" value="Request information (DEC-03)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#D8A72B;strokeWidth=2;endArrow=block;endFill=1;fontSize=10;fontColor=#8A5A00;labelBackgroundColor=#FFFFFF;exitX=0.25;exitY=0;exitDx=0;exitDy=0;entryX=0.25;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="submitted" target="awaiting">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" value="Respond &amp; resubmit (TRK-03)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#D8A72B;strokeWidth=2;endArrow=block;endFill=1;fontSize=10;fontColor=#8A5A00;labelBackgroundColor=#FFFFFF;exitX=0.75;exitY=1;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="awaiting" target="submitted">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" value="No response · auto-withdraw" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8B94A1;strokeWidth=1.5;dashed=1;endArrow=block;endFill=1;fontSize=10;fontColor=#5A6472;labelBackgroundColor=#FFFFFF;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="awaiting" target="withdrawn">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="90" y="165"/><mxPoint x="90" y="500"/><mxPoint x="235" y="500"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e7" value="informs" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0B5FFF;strokeWidth=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontColor=#003D9E;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="precheck" target="submitted">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e8" value="Approve (DEC-01)&#xa;step-up MFA" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#3A6B35;strokeWidth=2;endArrow=block;endFill=1;fontSize=10;fontColor=#2C5228;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="submitted" target="approved">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e9" value="Approve with conditions (DEC-04)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#3A6B35;strokeWidth=1.5;dashed=1;endArrow=block;endFill=1;fontSize=10;fontColor=#2C5228;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="submitted" target="approvedc">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e10" value="Reject (DEC-02) · reason code required" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#B3261E;strokeWidth=2;endArrow=block;endFill=1;fontSize=10;fontColor=#8F1D17;labelBackgroundColor=#FFFFFF;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="submitted" target="rejected">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="368" y="470"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e11" value="Amend &amp; resubmit as new request (TRK-04)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8B94A1;strokeWidth=1.5;dashed=1;endArrow=block;endFill=1;fontSize=10;fontColor=#5A6472;labelBackgroundColor=#FFFFFF;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="rejected" target="draft">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="360" y="550"/><mxPoint x="360" y="620"/><mxPoint x="235" y="620"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0F1723;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="approved" target="prov">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0F1723;strokeWidth=1.5;dashed=1;endArrow=block;endFill=1;" edge="1" parent="1" source="approvedc" target="prov">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e14" value="Smoke test passed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#3A6B35;strokeWidth=2;endArrow=block;endFill=1;fontSize=10;fontColor=#2C5228;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="prov" target="live">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e15" value="Smoke test failed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#D8A72B;strokeWidth=1.5;endArrow=block;endFill=1;fontSize=10;fontColor=#8A5A00;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="prov" target="liveu">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e16" value="Rollback (PRV-03)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#B3261E;strokeWidth=1.5;endArrow=block;endFill=1;fontSize=10;fontColor=#8F1D17;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="prov" target="provfail">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e17" value="Retry after fix" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8B94A1;strokeWidth=1.5;dashed=1;endArrow=block;endFill=1;fontSize=10;fontColor=#5A6472;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=1;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="provfail" target="prov">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="1075" y="470"/><mxPoint x="1170" y="470"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e18" value="Decommission approved (TRK-06)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8B94A1;strokeWidth=1.5;endArrow=block;endFill=1;fontSize=10;fontColor=#5A6472;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="live" target="decom">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="1560" y="283"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e19" value="Change request → new Draft (TRK-06)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8B94A1;strokeWidth=1.5;dashed=1;endArrow=block;endFill=1;fontSize=10;fontColor=#5A6472;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="live" target="draft">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="1340" y="100"/><mxPoint x="235" y="100"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e20" value="Withdraw (TRK-05)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8B94A1;strokeWidth=1.5;endArrow=block;endFill=1;fontSize=10;fontColor=#5A6472;labelBackgroundColor=#FFFFFF;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="submitted" target="draft">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="370" y="325"/><mxPoint x="370" y="325"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- LEGEND -->
        <mxCell id="lgbox" value="" style="rounded=1;arcSize=6;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DFE4EA;" vertex="1" parent="1">
          <mxGeometry x="40" y="690" width="1620" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="lgt" value="Hard rules encoded in this lifecycle" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#0F1723;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="702" width="500" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="lg1" value="1.  Segregation of duties (DEC-06). A requester is never offered the decision actions on their own request, and a direct API call to approve it is rejected server-side. Where the requester is the only approver in the group, the request routes to the escalation group rather than stalling." style="text;html=1;fontSize=11.5;fontColor=#3D4653;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="60" y="730" width="1580" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="lg2" value="2.  Step-up authentication (ADM-01). Approve, Reject, Approve-with-conditions and Request-information all require a fresh MFA challenge at the moment the decision is taken — not merely at sign-in." style="text;html=1;fontSize=11.5;fontColor=#3D4653;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="60" y="752" width="1580" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="lg3" value="3.  Config over construction (PRV-01). Provisioning writes ONE row to the config store, consumed by the existing generic MFT engine process or the standard gateway policy bundle. It never creates a new Boomi component per interface." style="text;html=1;fontSize=11.5;fontColor=#3D4653;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="60" y="774" width="1580" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="lg4" value="4.  SLA fairness (DEC-03 / TRK-03). Time spent in Awaiting Information is excluded from the approver's decision SLA, and the request returns to the same approver — not to the back of a generic queue." style="text;html=1;fontSize=11.5;fontColor=#3D4653;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="60" y="796" width="1580" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="lg5" value="5.  Nothing is destroyed. Rejected, Withdrawn and Decommissioned are all retained; a decommissioned interface has its config row disabled, never deleted. Every transition is written to the append-only audit trail (AUD-01)." style="text;html=1;fontSize=11.5;fontColor=#3D4653;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="60" y="818" width="1580" height="20" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
